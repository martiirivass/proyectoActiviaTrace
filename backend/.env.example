# Base de datos
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/activia_trace
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5432/activia_trace_test

# Seguridad JWT
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Clave de cifrado AES-256 para PII (exactamente 32 caracteres)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Tiempo de expiración del access token en minutos (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# OpenTelemetry (opcional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=activia-trace-api