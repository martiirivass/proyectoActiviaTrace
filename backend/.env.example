# ──────────────────────────────────────────────
# activia-trace — Variables de Entorno (Backend)
# ──────────────────────────────────────────────
# Copiar a .env y ajustar para el entorno local.

# Base de datos
# Docker Compose expone PostgreSQL en puerto 5433 (local: 5432)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/activia_trace
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5433/activia_trace_test

# Seguridad JWT
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Clave de cifrado AES-256 para PII (exactamente 32 caracteres)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Tiempo de expiración del access token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256
2FA_TOKEN_EXPIRE_MINUTES=5

# OpenTelemetry (opcional — requiere collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=activia-trace-api

# Moodle (opcional — deshabilitado por defecto)
MOODLE_ENABLED=false
MOODLE_URL=
MOODLE_TOKEN=

# SMTP (usado por el worker de comunicaciones)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@activia-trace.com

# Worker
WORKER_POLL_INTERVAL=30
WORKER_BATCH_SIZE=20
